      "info": {
        "name": "Status ",
        "type": "http"
      },
      "http": {
        "method": "GET",
        "url": "{{baseUrl}}/status"
      },
      "docs": "Status "
    },
    {
      "info": {
        "name": "Chat Completions",
        "type": "http"
      },
      "http": {
        "method": "POST",
        "url": "{{baseUrl}}/v1/chat/completions",
        "body": {
          "type": "json",
          "data": "{}"
        },
        "auth": {
          "type": "oauth2",
          "flow": "resource_owner_password_credentials",
          "accessTokenUrl": "token",
          "credentials": {
            "clientId": "{{clientId}}",
            "clientSecret": "{{clientSecret}}"
          }
        }
      },
      "docs": "Chat completions endpoint for Inflection hosted models.\n\n⚠️ This endpoint is under active development to enable all Inflection model and config types."
    },
    {
      "info": {
        "name": "Chat Attributes",
