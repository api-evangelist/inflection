          "type": "oauth2",
          "flow": "resource_owner_password_credentials",
          "accessTokenUrl": "token",
          "credentials": {
            "clientId": "{{clientId}}",
            "clientSecret": "{{clientSecret}}"
          }
        }
      },
      "docs": "Get attribute scores for the most recent assistant message in a chat completions style request.\n\n⚠️ Experimental endpoint for evaluating message attributes."
